[user]
	name = John Williams
	email = john@rover.com
[core]
	excludesfile = ~/.gitignore
	editor = nvim
	templatedir = ~/.git_template
[alias]
	co = checkout
[color]
	branch = auto
	diff = auto
	status = auto
	interactive = auto
[push]
	default = simple
[diff]
	tool = nvimdiff
[difftool]
	prompt = false
[difftool "nvimdiff"]
	cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""
[merge]
	tool = nvimdiff
